{
  "name": "@dwengochart/renderer",
  "version": "0.1.0",
  "description": "Canvas rendering library for financial charts — candlestick, line, area series, axes, crosshairs, and interactions",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "chart",
    "trading",
    "canvas",
    "candlestick",
    "renderer",
    "financial",
    "typescript"
  ],
  "author": "dweng0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dweng0/dwengochart-renderer"
  },
  "dependencies": {
    "@dwengochart/core": "github:dweng0/dwengochart-core",
    "@yatamazuki/typed-eventbus": "^1.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
